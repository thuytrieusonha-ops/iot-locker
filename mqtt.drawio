                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD;\n    START([FastAPI yêu cầu mở tủ]) --&gt; ENABLE{Hardware được bật?};\n\n    ENABLE --&gt;|Không| SIMULATE[Mô phỏng mở tủ];\n    SIMULATE --&gt; END([Kết thúc]);\n\n    ENABLE --&gt;|Có| ID[Sinh request_id bằng UUID];\n    ID --&gt; WAITACK[Lưu request_id để chờ ACK];\n    WAITACK --&gt; PUBLISH[Publish lệnh open lên MQTT];\n    PUBLISH --&gt; BROKER[(Mosquitto Broker)];\n    BROKER --&gt; GATEWAY[Gateway nhận message];\n    GATEWAY --&gt; VALID{Payload và locker_id hợp lệ?};\n\n    VALID --&gt;|Không| IGNORE[Bỏ qua message];\n    IGNORE --&gt; END;\n\n    VALID --&gt;|Có| DUP{Trạng thái request_id?};\n    DUP --&gt;|Đã hoàn thành| REPLAY[Phát lại ACK đã lưu];\n    DUP --&gt;|Đang xử lý| WAIT[Chờ lệnh trước hoàn thành];\n    DUP --&gt;|Lệnh mới| UART[Gửi UART OPEN và locker_id];\n\n    UART --&gt; MEGA[Arduino Mega điều khiển khóa];\n    MEGA --&gt; RESPONSE{Mega trả OK đúng thời hạn?};\n\n    RESPONSE --&gt;|Không| ERRORACK[Publish ACK error];\n    RESPONSE --&gt;|Có| OKACK[Publish ACK opened];\n\n    REPLAY --&gt; RECEIVE[FastAPI nhận ACK theo request_id];\n    WAIT --&gt; RECEIVE;\n    ERRORACK --&gt; RECEIVE;\n    OKACK --&gt; RECEIVE;\n\n    RECEIVE --&gt; SUCCESS{ACK có trạng thái thành công?};\n    SUCCESS --&gt;|Không| HWERROR[Thông báo lỗi phần cứng];\n    HWERROR --&gt; END;\n\n    SUCCESS --&gt;|Có| CONTEXT{Ngữ cảnh mở tủ?};\n    CONTEXT --&gt;|Quản trị| FINISH[Hoàn thành lệnh];\n\n    CONTEXT --&gt;|Giao hàng| DOOR[Chờ door_open rồi door_closed];\n    DOOR --&gt; CLOSED{Cửa đã đóng đúng thời hạn?};\n    CLOSED --&gt;|Không| DOORERROR[Thông báo lỗi cửa tủ];\n    DOORERROR --&gt; END;\n    CLOSED --&gt;|Có| USED[Publish set_occupied true];\n    USED --&gt; UARTUSED[Gửi UART LOCKER_USED];\n    UARTUSED --&gt; FINISH;\n\n    CONTEXT --&gt;|Nhận hàng| EMPTY[Publish set_occupied false];\n    EMPTY --&gt; UARTEMPTY[Gửi UART LOCKER_EMPTY];\n    UARTEMPTY --&gt; FINISH;\n\n    FINISH --&gt; COMPLETE([Kết thúc]);&quot;&#xa;}" id="2">
